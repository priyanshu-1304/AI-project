import pandas as pd
from datetime import datetime
import time
import os

# Folder path
folder_path = r"C:/Users/vikit/Desktop/attendence_marked"

# Create folder if not exists
if not os.path.exists(folder_path):
    os.makedirs(folder_path)

# File path
file_name = os.path.join(folder_path, "attendance.csv")

# Start camera
cap = cv2.VideoCapture(0)

name = input("Enter your name: ")

print("Camera starting... Adjust yourself in light")
time.sleep(3)

ret, frame = cap.read()

if not ret:
    print("Camera error")
    cap.release()
    exit()

# Improve brightness & quality
frame = cv2.convertScaleAbs(frame, alpha=1.5, beta=40)  # brightness
frame = cv2.GaussianBlur(frame, (5, 5), 0)  # smooth image

# Show captured image
cv2.imshow("Captured Photo", frame)

# Create CSV if not exists
if not os.path.exists(file_name):
    df = pd.DataFrame(columns=["Name", "Time"])
    df.to_csv(file_name, index=False)

# Load file
df = pd.read_csv(file_name)

# Mark attendance
if name not in df["Name"].values:
    now = datetime.now()
    time_now = now.strftime("%H:%M:%S")

    new_entry = pd.DataFrame([[name, time_now]], columns=["Name", "Time"])
    df = pd.concat([df, new_entry], ignore_index=True)
    df.to_csv(file_name, index=False)

    print("Attendance Marked ")
else:
    print("Already Marked ")

# Save photo in folder
image_path = os.path.join(folder_path, f"{name}.jpg")
cv2.imwrite(image_path, frame)

print("Photo saved in folder ")

cv2.waitKey(3000)

cap.release()
cv2.destroyAllWindows()
